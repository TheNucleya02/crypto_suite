# ============================================================
# Momentum Crypto Suite — Frontend Environment Variables
# Copy this file to frontend/.env and fill in your values.
# NEVER commit frontend/.env to version control.
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# URL of the FastAPI backend.
# Development default: http://localhost:8000
# Production: set this to your deployed backend URL.
VITE_API_BASE_URL=http://localhost:8000

# ── Supabase (optional) ──────────────────────────────────────
# Only needed for chat thread + cloud portfolio persistence.
# Without these the app falls back to the FastAPI backend for
# portfolio and disables cloud chat history.
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
