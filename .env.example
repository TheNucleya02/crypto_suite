# ============================================================
# Momentum Crypto Suite — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── JWT Security ─────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET=your-strong-random-secret-here

# ── AI / LLM ─────────────────────────────────────────────────
# Hugging Face access token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face model path (optional — defaults to Llama-3.1-8B-Instruct)
HF_MODEL=huggingface/meta-llama/Llama-3.1-8B-Instruct

# ── External Data APIs ───────────────────────────────────────
# Exa (news search) — https://exa.ai
EXA_API=your-exa-api-key

# Alpha Vantage (historical crypto prices) — https://www.alphavantage.co/support/#api-key
ALPHA_API=your-alpha-vantage-key

# CoinMarketCap (Fear & Greed index) — https://coinmarketcap.com/api/
CMC_API=your-coinmarketcap-key

# ── CORS (Production) ────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave as * for local development; set explicitly for production.
# Example: CORS_ORIGINS=https://myapp.replit.app,https://mycustomdomain.com
CORS_ORIGINS=*
